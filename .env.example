# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Phase 2: Essay coach — server-only, never prefix with NEXT_PUBLIC_
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Phase 3: Local scraper — server-only
# Service-role key from Supabase -> Project Settings -> API. Used by /api/scrape
# to upsert scraped scholarships bypassing RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret the Vercel Cron (and manual curl triggers) must send as
# `Authorization: Bearer $CRON_SECRET` when hitting /api/scrape or /api/reminders.
# Generate with: openssl rand -hex 32
CRON_SECRET=change-me

# Phase 2/3: Deadline reminder emails — server-only.
# Resend API key: https://resend.com/api-keys. Required by the daily
# /api/reminders cron that sends digest emails to students with upcoming
# application deadlines.
RESEND_API_KEY=re_...

# The From address for outbound email. Must be a domain you've verified
# in Resend (https://resend.com/domains). Example:
#   "ScholarshipOS <no-reply@scholarshipos.app>"
# Until the domain is verified you can use Resend's sandbox address
# `onboarding@resend.dev` but it only delivers to the account owner's
# email for testing.
EMAIL_FROM=ScholarshipOS <no-reply@scholarshipos.app>

# Public-facing base URL used in reminder email links (button to /kanban,
# preferences link). Defaults to https://scholarshipos.app if unset.
NEXT_PUBLIC_APP_URL=https://scholarshipos.app

# Local dev only: set to 1 to skip @sparticuz/chromium and use the system
# Chrome/Chromium via playwright-core's default launcher. Do NOT set this in
# production — Vercel's Node runtime needs the sparticuz binary.
# PLAYWRIGHT_LOCAL=1
